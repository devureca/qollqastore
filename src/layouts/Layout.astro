---
import "../styles/global.css";

interface Props {
    title: string;
    description?: string;
    image?: string;
    color?: string;
    faviconLetras?: string;
}

const {
    title,
    description = "Catálogo digital creado con QollqaStore",
    image,
    color = "#6366f1",
    faviconLetras = "Q",
} = Astro.props;

const letras = faviconLetras.slice(0, 2).toUpperCase();

const faviconSvg = `<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100">
  <rect width="100" height="100" rx="16" fill="#000000"/>
  <text x="50" y="${letras.length === 1 ? "68" : "63"}" text-anchor="middle" font-size="${letras.length === 1 ? "62" : "46"}" font-family="Arial, sans-serif" font-weight="bold" fill="#ffffff">${letras}</text>
</svg>`;

const faviconUrl = `data:image/svg+xml,${encodeURIComponent(faviconSvg)}`;

const siteUrl = Astro.site
    ? Astro.site.origin
    : "https://qollqastore.vercel.app";
const canonicalURL = new URL(Astro.url.pathname, siteUrl);

let socialImageURL = null;
if (image) {
    try {
        socialImageURL = new URL(image, siteUrl);
    } catch (e) {
        socialImageURL = null;
    }
}
---

<!doctype html>
<html lang="es">
    <head>
        <meta charset="UTF-8" />
        <meta name="viewport" content="width=device-width, initial-scale=1.0" />
        <title>{title}</title>
        <meta name="description" content={description} />
        <link rel="icon" type="image/svg+xml" href={faviconUrl} />

        <meta property="og:type" content="website" />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={title} />
        <meta property="og:description" content={description} />
        {
            socialImageURL && (
                <meta property="og:image" content={socialImageURL} />
            )
        }

        <meta property="twitter:card" content="summary_large_image" />
        <meta property="twitter:url" content={canonicalURL} />
        <meta property="twitter:title" content={title} />
        <meta property="twitter:description" content={description} />
        {
            socialImageURL && (
                <meta property="twitter:image" content={socialImageURL} />
            )
        }

        <style define:vars={{ color }}>
            :root {
                --color-primary: var(--color);
            }
        </style>
        <script is:inline>
            const t = localStorage.getItem("theme") || "light";
            document.documentElement.setAttribute("data-theme", t);
            document.documentElement.classList.add("ready");
        </script>
    </head>
    <body>
        <slot />
    </body>
</html>
