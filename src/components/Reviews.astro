---
import type { Review } from '../types'

interface Props {
  reviews: Review[]
}

const { reviews } = Astro.props
---

<div class="py-16" style="background: var(--bg-secondary);">
  <div class="max-w-7xl mx-auto px-[5%]">

    <!-- Header -->
    <p class="text-xs font-bold uppercase tracking-widest mb-2" style="color: var(--text-muted);">Testimonios</p>
    <h2 style="font-family: var(--font-display); font-size: clamp(2rem, 4vw, 3rem); letter-spacing: 0.05em; color: var(--text);">CLIENTES FELICES</h2>

    <!-- Lista -->
    <div class="flex flex-col mt-10">
      {reviews.map((review, i) => (
        <div
          class={`py-8 grid grid-cols-1 md:grid-cols-[220px_1fr] gap-6 md:gap-12 ${i < reviews.length - 1 ? 'border-b' : ''}`}
          style="border-color: var(--border);"
        >
          <!-- Avatar, nombre y estrellas -->
          <div class="flex md:flex-col items-center md:items-start gap-4 md:gap-3">
            <div
              class="w-14 h-14 md:w-16 md:h-16 rounded-full flex items-center justify-center shrink-0 text-white"
              style="background: var(--color-primary); font-family: var(--font-display); font-size: 1.6rem;"
            >
              {review.nombre.charAt(0).toUpperCase()}
            </div>
            <div>
              <p class="font-bold text-base" style="color: var(--text);">{review.nombre}</p>
              <p class="text-sm mt-0.5" style="color: #f59e0b;">{'★'.repeat(Number(review.estrellas))}<span class="ml-1 text-xs" style="color: var(--text-muted);">{review.estrellas}/5</span></p>
            </div>
          </div>

          <!-- Texto reseña -->
          <div class="flex items-center">
            <p class="text-base leading-relaxed" style="color: var(--text-muted);">"{review.texto}"</p>
          </div>
        </div>
      ))}
    </div>

  </div>
</div>